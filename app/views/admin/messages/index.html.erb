<div class="page-sub">Boite de reception des demandes clients envoyees depuis le site public.</div>

<div class="panel panel--messages">
  <div class="panel-header">
    <div class="panel-title">Messages recus</div>
    <select id="msg-filter" aria-label="Filtrer les messages">
      <option value="">Tous les messages</option>
      <option value="unread">Non lus</option>
      <option value="read">Lus</option>
    </select>
  </div>

  <div class="table-responsive">
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Expediteur</th>
          <th>Message</th>
          <th>Statut</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @messages.each do |message| %>
          <tr class="<%= admin_message_row_class(message) %>" data-read="<%= message.read? ? "read" : "unread" %>">
            <td class="msg-date">
              <%= admin_message_datetime(message) %>
              <div class="msg-time"><%= admin_message_time(message) %></div>
            </td>
            <td>
              <strong><%= message.sender_name %></strong>
              <div class="msg-email"><%= mail_to message.sender_email %></div>
            </td>
            <td class="msg-preview"><%= admin_message_preview(message) %></td>
            <td>
              <span class="badge <%= admin_message_status_badge_class(message) %>"><%= admin_message_status_label(message) %></span>
            </td>
            <td>
              <div class="td-actions">
                <%= link_to(message.read? ? "Voir" : "Lire", admin_message_path(message), class: "btn #{message.read? ? 'btn--outline' : 'btn--primary'} btn--sm") %>
                <% unless message.read? %>
                  <%= button_to "Marquer lu", admin_message_path(message), method: :patch, class: "btn btn--outline btn--sm" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
