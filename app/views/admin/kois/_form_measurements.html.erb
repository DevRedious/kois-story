<div class="form-section">
  <div class="form-section-title"><span class="section-num">2</span> Dimensions et prix</div>
  <div class="form-grid">
    <div class="form-group">
      <%= f.label :size_cm, "Taille (cm)" %>
      <span class="required">*</span>
      <%= f.number_field :size_cm, placeholder: "Ex : 72", min: 5, max: 150, required: true %>
      <span class="form-hint">Taille actuelle mesuree</span>
    </div>

    <div class="form-group">
      <%= f.label :price, "Prix (€)" %>
      <span class="required">*</span>
      <div class="price-wrap">
        <%= f.number_field :price, placeholder: "1800", min: 0, step: 10, required: true %>
      </div>
      <span class="form-hint">Prix TTC affiche sur la fiche</span>
    </div>

    <div class="form-group">
      <%= f.label :age, "Age (ans)" %>
      <%= f.number_field :age, min: 0, max: 30, placeholder: "Ex : 2" %>
    </div>
  </div>

  <div class="form-group mt-2">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, placeholder: "Particularites, historique, remarques sur le motif..." %>
  </div>
</div>
