<div class="form-section">
  <div class="form-section-title"><span class="section-num">4</span> Photos</div>

  <label class="upload-zone" for="koi-images">
    <div class="upload-icon">
      <svg aria-hidden="true" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <polyline points="21 15 16 10 5 21"></polyline>
      </svg>
    </div>
    <div class="upload-label">Cliquez pour ajouter des photos</div>
    <div class="upload-hint">JPG, PNG, WebP · Premiere photo = image principale</div>
    <%= file_field_tag "koi[uploaded_images][]", multiple: true, accept: "image/*", id: "koi-images", aria: { label: "Fichiers photos du koi" } %>
  </label>

  <div class="img-preview" id="img-preview">
    <% koi.images.order(:position).each do |image| %>
      <div class="img-thumb">
        <% if resolved_image_source(image).present? %>
          <%= image_tag resolved_image_source(image), alt: image.alt.presence || "Photo du koi" %>
        <% else %>
          <div class="koi-thumb koi-thumb-sm">?</div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="cloudinary-note">Les nouvelles photos seront ajoutees au koi lors de l'enregistrement.</div>
</div>
