<div class="form-section">
  <div class="form-section-title"><span class="section-num">1</span> Identite</div>
  <div class="form-grid">
    <div class="form-group">
      <%= f.label :name, "Nom du koi" %>
      <span class="required">*</span>
      <%= f.text_field :name, placeholder: "Ex : Sakura", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :variety, "Variete" %>
      <span class="required">*</span>
      <%= f.select :variety, options_for_select(variety_options, koi.variety), { include_blank: "— Selectionner —" }, { required: true, aria: { label: "Variete" } } %>
    </div>

    <div class="form-group">
      <%= f.label :age_class, "Classe d'age" %>
      <span class="required">*</span>
      <%= f.select :age_class, options_for_select(age_class_options, koi.age_class), { include_blank: "— Selectionner —" }, { required: true, aria: { label: "Classe d'age" } } %>
    </div>

    <div class="form-group">
      <%= f.label :sex, "Sexe" %>
      <%= f.select :sex, options_for_select(sex_options, koi.sex), {}, { aria: { label: "Sexe" } } %>
    </div>
  </div>
</div>
