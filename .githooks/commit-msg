#!/bin/sh

commit_msg=$(cat "$1")

# Ignorer les commits de merge et les [skip ci]
echo "$commit_msg" | grep -qE "^Merge |^\[skip ci\]" && exit 0

# Valider le format conventionnel
pattern="^(feat|fix|docs|style|refactor|chore|test|perf|build|ci|revert)(\(.+\))?: .{1,100}"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  Commit refusé — format invalide."
  echo ""
  echo "  Format attendu :"
  echo "    <type>: <description courte>"
  echo ""
  echo "  Types disponibles :"
  echo "    feat     → nouvelle fonctionnalité"
  echo "    fix      → correction de bug"
  echo "    docs     → documentation, README"
  echo "    style    → CSS, mise en forme (pas de logique)"
  echo "    refactor → réorganisation du code sans changement de comportement"
  echo "    chore    → maintenance, config, dépendances"
  echo "    test     → ajout ou correction de tests"
  echo "    perf     → amélioration des performances"
  echo "    build    → système de build, dépendances externes"
  echo "    ci       → configuration CI/CD (GitHub Actions, etc.)"
  echo "    revert   → annulation d'un commit précédent"
  echo ""
  echo "  Exemples valides :"
  echo "    feat: ajouter le bouton WhatsApp sur la fiche produit"
  echo "    fix: corriger l'affichage du prix sur mobile"
  echo "    style: harmoniser les couleurs du footer"
  echo "    chore: mettre à jour biome.json"
  echo ""
  echo "  Ton message :"
  echo "    \"$commit_msg\""
  echo ""
  exit 1
fi

exit 0
