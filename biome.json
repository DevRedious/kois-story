{
  "files": {
    "includes": [
      "**",
      "!**/*.html",
      "!**/.vscode",
      "!**/.edge",
      "!**/edge-tools"
    ]
  },
  "linter": {
    "rules": {
      "complexity": {
        "noImportantStyles": "warn"
      },
      "style": {
        "noDescendingSpecificity": "warn"
      }
    }
  }
}
