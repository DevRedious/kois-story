{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/*.html",
			"!**/.vscode",
			"!**/.edge",
			"!**/edge-tools",
			"!koi_story_ui_mockup.jsx"
		]
	},
	"linter": {
		"rules": {
			"complexity": {
				"noImportantStyles": "warn"
			},
			"style": {
				"noDescendingSpecificity": "warn"
			}
		}
	}
}
